        function updateCalculator() {
            const reqVal = parseInt(document.getElementById("sliderRequests").value);
            const cacheVal = parseInt(document.getElementById("sliderCache").value) / 100;
            const priceVal = parseFloat(document.getElementById("sliderPrice").value);
            const outageVal = parseFloat(document.getElementById("sliderOutage").value) / 100;

            document.getElementById("valRequests").innerText = reqVal.toLocaleString();
            document.getElementById("valCache").innerText = Math.round(cacheVal * 100) + "%";
            document.getElementById("valPrice").innerText = "$" + priceVal.toFixed(4);
            document.getElementById("valOutage").innerText = (outageVal * 100).toFixed(1) + "%";

            const avgTokensPerRequest = 2500;
            const rawMonthlyCost = (reqVal * (avgTokensPerRequest / 1000)) * priceVal;
            const monthlySavings = rawMonthlyCost * cacheVal;
            const annualSavings = monthlySavings * 12;
            const latencySaved = Math.round(cacheVal * 1485);
            const protectedRequests = Math.round(reqVal * outageVal);

            document.getElementById("resMonthlySavings").innerText = "$" + monthlySavings.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById("resAnnualSavings").innerText = "$" + annualSavings.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById("resLatency").innerText = "-" + latencySaved + "ms";
            document.getElementById("resDowntime").innerText = protectedRequests.toLocaleString() + "/yr";
        }
