                ["/v1/.../openai/chat/completions", "gpt-4o"],
                ["dynamic/support", "fallback -> gpt-4o-mini"],
            ];
            const outcomes = [
                ["HIT", "t-hit"], ["MISS", "t-miss"], ["MISS", "t-miss"], ["HIT", "t-hit"],
                ["FLAG", "t-flag"], ["MISS", "t-miss"], ["HIT", "t-hit"], ["BLOCK", "t-block"]
            ];
            const body = document.getElementById("traceBody");
            const counter = document.getElementById("traceCount");
            let count = 0;
            function pad(n) { return n < 10 ? "0" + n : n; }
            function addRow() {
                if (!body) return;
                const now = new Date();
                const time = pad(now.getHours()) + ":" + pad(now.getMinutes()) + ":" + pad(now.getSeconds());
                const [path, model] = paths[Math.floor(Math.random() * paths.length)];
                const [status, cls] = outcomes[Math.floor(Math.random() * outcomes.length)];
                const lat = status === "HIT" ? (Math.random() * 12 + 3).toFixed(0) : (Math.random() * 900 + 250).toFixed(0);
                const row = document.createElement("div");
                row.className = "trace-row";
                row.innerHTML = '<span class="t-time">' + time + '</span><span class="t-path">' + path + ' &middot; ' + model + '</span><span class="t-status ' + cls + '">' + status + ' ' + lat + 'ms</span>';
                body.insertBefore(row, body.firstChild);
                while (body.children.length > 9) body.removeChild(body.lastChild);
                count++;
                if (counter) counter.innerText = count.toLocaleString() + " req";
            }
            for (let i = 0; i < 6; i++) addRow();
            setInterval(addRow, 1400);
        })();
